# ============================================================
# LinkedIn AI Content Automation System — Environment Variables
# Copy this file to .env and fill in your credentials
# ============================================================

# ── GOOGLE GEMINI API ──────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── LINKEDIN API ───────────────────────────────────────────
# How to get these:
# 1. Go to https://www.linkedin.com/developers/apps
# 2. Create a new app → select "Share on LinkedIn" + "Sign In with LinkedIn"
# 3. Under "Auth" tab → get Client ID & Client Secret
# 4. Request OAuth 2.0 scopes: w_member_social, r_liteprofile, r_emailaddress
# 5. Generate access token (valid 60 days) via OAuth flow
#    Quick method: Use LinkedIn OAuth 2.0 Playground or Postman
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID_HERE
# To get your Person URN:
#   GET https://api.linkedin.com/v2/userinfo with your access token
#   Copy the "sub" field value → that's your person ID

# ── OPTIONAL: TWITTER/X API ───────────────────────────────
# Enables trending discussions as a research source
X_BEARER_TOKEN=

# ── OPTIONAL: REDDIT API ──────────────────────────────────
# Enables Reddit trending posts as a research source
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=LinkedInBot/1.0

# ── OPTIONAL: NEWS API ────────────────────────────────────
# https://newsapi.org — free tier (100 requests/day)
# Enables broader news research
NEWS_API_KEY=

# ── DASHBOARD SETTINGS ────────────────────────────────────
DASHBOARD_PORT=5000
DASHBOARD_SECRET_KEY=change_this_to_a_random_string

# ── AUTOMATION SETTINGS ───────────────────────────────────
# Timezone for scheduling
TIMEZONE=Asia/Kolkata

# Your LinkedIn brand/creator name
BRAND_NAME=AI Insights

# Your primary industry/niche (used to focus content)
CONTENT_NICHE=Artificial Intelligence, Tech, Business, Startups

# ── POSTING SCHEDULE ─────────────────────────────────────
# Daily research and generation times
RESEARCH_TIME=08:00
SELECT_TIME=08:20
GENERATE_TIME=08:30
SCHEDULE_TIME=08:50

# 5 daily post times (24-hour HH:MM)
POST_TIME_1=09:05
POST_TIME_2=10:45
POST_TIME_3=12:30
POST_TIME_4=14:30
POST_TIME_5=16:30
